# Copy this file to .env for local development.
# In Railway/Render, set these as environment variables in the dashboard.

# ── Required ─────────────────────────────────────────────────────────────────

# Supabase project URL and service role key (Settings → API in Supabase dashboard)
SUPABASE_URL=https://gyjpffsrpixokybfrowt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Optional: tuning ─────────────────────────────────────────────────────────

# How often to poll for new jobs (seconds). Default: 10
POLL_INTERVAL_SECONDS=10

# ── Optional: IAAI authentication ────────────────────────────────────────────

# IAAI session cookies as a JSON string.
# Obtain by logging into iaai.com and copying cookies from DevTools.
# Refresh every ~30 days when IAAI session expires.
# Example: {"session": "abc123", "auth_token": "xyz"}
IAAI_SESSION_COOKIES=

# ── Optional: email alerts ────────────────────────────────────────────────────

# Admin email to receive failure alerts
ALERT_ADMIN_EMAIL=spiritledtech@gmail.com

# SMTP credentials for sending alerts. Any SMTP relay works (Gmail, Sendgrid, Mailgun).
# If not set, alerts are logged only (not emailed).
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your-email@gmail.com
ALERT_SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=autolot-alerts@yourdomain.com
